{
  "name": "tinymon",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node index.js",
    "dev": "nodemon index.js",
    "dev:ts": "nodemon --exec ts-node src/server/index.ts",
    "start:ts": "ts-node src/server/index.ts",
    "clean": "rimraf dist",
    "copy:vendor": "node scripts/copy-vendor.js",
    "build": "webpack --config webpack.config.js",
    "build:client": "npm run copy:vendor && webpack --config webpack.client.config.js",
    "build:all": "npm run clean && npm run build && npm run build:client",
    "build:legacy": "npm run build:client && node build.js --no-clean",
    "start:prod": "cd dist && node bundle.js",
    "type-check": "tsc --noEmit",
    "type-check:client": "tsc --noEmit --project tsconfig.client.json"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "body-parser": "^2.2.2",
    "cookie-parser": "^1.4.7",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.66.0"
  },
  "peerDependencies": {
    "mysql2": "*",
    "pg": "*"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@types/body-parser": "^1.19.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "*",
    "babel-loader": "^10.1.1",
    "copy-webpack-plugin": "^14.0.0",
    "fs-extra": "^11.3.4",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "typeface-inter": "^3.18.1",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-node-externals": "^3.0.0"
  }
}
