<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="date-format" content="<%= dateFormat %>">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css">
    <link rel="stylesheet" href="/vendor/inter/inter.css">
</head>
<body>
    <div class="container">
        <header class="header">
            <div class="header-top">
                <div>
                    <h1><i class="fas fa-heartbeat"></i> TinyMon</h1>
                    <p class="subtitle">Service availability monitoring</p>
                </div>
                <% if (user) { %>
                <div class="user-info">
                    <i class="fas fa-user"></i> <%= user %>
                    <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Logout</a>
                </div>
                <% } %>
            </div>
        </header>

        <div class="stats-cards">
            <div class="stat-card total">
                <h3>Total services</h3>
                <p class="stat-number"><%= total %></p>
            </div>
            <div class="stat-card ok">
                <h3>OK</h3>
                <p class="stat-number"><%= okCount %></p>
            </div>
            <div class="stat-card warning">
                <h3>WARNING</h3>
                <p class="stat-number"><%= warningCount %></p>
            </div>
            <div class="stat-card error">
                <h3>ERROR</h3>
                <p class="stat-number"><%= errorCount %></p>
            </div>
        </div>

        <main class="main">
            <div class="services-header">
                <h2><i class="fas fa-server"></i> Service status</h2>
                <div class="last-update">
                    Last update: <span id="last-update-time"><%= new Date().toLocaleTimeString() %></span>
                    <button id="refresh-btn" class="refresh-btn"><i class="fas fa-sync-alt"></i> Refresh</button>
                </div>
            </div>

            <div class="groups-container">
                <% if (groups.length === 0) { %>
                <div class="no-services">
                    <i class="fas fa-inbox"></i>
                    <p>No services configured for monitoring.</p>
                    <p>Add configuration files to the <code>settings.d</code> folder</p>
                </div>
                <% } else { %>
                    <% groups.forEach(group => { %>
                    <div class="service-group" data-group-name="<%= group.name %>">
                        <div class="group-header <%= group.allOk ? 'collapsed' : 'expanded' %>" data-group-name="<%= group.name %>">
                            <div class="group-title">
                                <i class="fas fa-chevron-down group-chevron"></i>
                                <h3><%= group.name %></h3>
                                <div class="group-stats">
                                    <span class="group-stat total"><%= group.services.length %> services</span>
                                    <% if (group.okCount > 0) { %>
                                        <span class="group-stat ok"><i class="fas fa-check-circle"></i> <%= group.okCount %></span>
                                    <% } %>
                                    <% if (group.warningCount > 0) { %>
                                        <span class="group-stat warning"><i class="fas fa-exclamation-triangle"></i> <%= group.warningCount %></span>
                                    <% } %>
                                    <% if (group.errorCount > 0) { %>
                                        <span class="group-stat error"><i class="fas fa-times-circle"></i> <%= group.errorCount %></span>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                        <div class="group-body <%= group.allOk ? 'collapsed' : 'expanded' %>" data-group-name="<%= group.name %>">
                            <table class="services-table">
                                <thead>
                                    <tr>
                                        <th>Service</th>
                                        <th>Type</th>
                                        <th>Address</th>
                                        <th>Interval</th>
                                        <th>Status</th>
                                        <th>Failures</th>
                                        <th>Last check</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% group.services.forEach(service => { %>
                                    <tr class="service-row" data-service-id="<%= service.id %>">
                                        <td class="service-name">
                                            <i class="fas <%= service.type === 'http' ? 'fa-globe' : service.type === 'ssl' ? 'fa-lock' : 'fa-network-wired' %>"></i>
                                            <%= service.name %>
                                        </td>
                                        <td class="service-type"><%= service.type.toUpperCase() %></td>
                                        <td class="service-address"><%= service.address %></td>
                                        <td class="service-interval"><%= service.interval %> sec</td>
                                        <td class="service-status">
                                            <span class="status-badge status-<%= service.status.toLowerCase() %>">
                                                <%= service.status %>
                                                <% if (service.type === 'ssl' && service.ssl_days_until_expiry !== null) { %>
                                                    <% if (service.ssl_days_until_expiry <= 0) { %>
                                                        (<%= Math.abs(service.ssl_days_until_expiry) %> days ago)
                                                    <% } else { %>
                                                        (<%= service.ssl_days_until_expiry %> days)
                                                    <% } %>
                                                <% } %>
                                            </span>
                                        </td>
                                        <td class="service-failures">
                                            <span class="failure-count"><%= service.failure_count %></span>
                                        </td>
                                        <td class="service-last-check">
                                            —
                                        </td>
                                        <td class="service-actions">
                                            <button class="action-btn check-btn" title="Check now">
                                                <i class="fas fa-bolt"></i>
                                            </button>
                                            <button class="action-btn history-btn" title="Check history">
                                                <i class="fas fa-history"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <% }) %>
                <% } %>
            </div>
        </main>

        <footer class="footer">
            <p>TinyMon &copy; <%= new Date().getFullYear() %> | IP/HTTP/HTTPS resource monitoring</p>
            <p class="version">Version 1.0.0 | Node.js <%= process.version %></p>
        </footer>
    </div>

    <!-- Check history modal -->
    <div id="history-modal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Check history</h3>
                <button class="close-modal">&times;</button>
            </div>
            <div class="modal-body">
                <div id="history-content">
                    <!-- Content will be loaded via JavaScript -->
                </div>
            </div>
        </div>
    </div>

    <script src="/js/app.js"></script>
</body>
</html>